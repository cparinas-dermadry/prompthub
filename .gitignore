# npm lockfile — this is a pnpm project, don't commit npm lockfiles
package-lock.json

# Dependencies
node_modules/

# Environment variables - never commit these
.env
.env.local
.env.production
.env.*.local
# .env.example IS committed — it documents required variables without secrets

