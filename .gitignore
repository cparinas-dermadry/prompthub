dist/
.next/
out/
build/

# Turbo cache
.turbo/

# TypeScript incremental build
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Vercel
.vercel

# Test coverage
coverage/
