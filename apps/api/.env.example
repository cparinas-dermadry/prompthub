# NestJS API — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── Clerk ──────────────────────────────────────────────────────────────────────
# From: Clerk dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
# From: Clerk dashboard → JWT Templates (create one if not present).
# Pins verifyToken to this issuer so a different Clerk app's tokens can't
# be accepted even if the secret were ever shared/leaked.
CLERK_ISSUER_URL=https://<your-clerk-instance>.clerk.accounts.dev
# Comma-separated list of frontend origins allowed to mint tokens for this
# API. Without this set, ANY Clerk-issued token signed by the same secret
# is accepted. Match your real frontend URL(s).
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase project → Settings → API
SUPABASE_URL=https://<your-project>.supabase.co
# Service-role key — full DB access, bypasses RLS. Used for system/admin
# operations. Keep this secret; treat it like a root password.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon (publishable) key — used by UserSupabaseService together with the
# request's Clerk JWT, so the per-request Supabase client runs UNDER RLS.
# Once Phase 2 of the RLS rollout flips services over, this key is what
# actually serves user traffic. Safe to expose to the client (also lives in
# apps/web's NEXT_PUBLIC_* config if you ever query Supabase from the
# browser directly).
SUPABASE_ANON_KEY=eyJ...

# ── OpenRouter ────────────────────────────────────────────────────────────────
# From: openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-...

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Production: set to your Vercel URL e.g. https://prompthub.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Rate limiting (optional — overrides defaults) ─────────────────────────────
# Generic per-IP cap applied to every route. Default: 60 req per 60s.
# THROTTLE_DEFAULT_LIMIT=60
# THROTTLE_DEFAULT_TTL_MS=60000

# Stricter per-IP cap on POST /streaming/prompt — each call fans out to up
# to 10 paid OpenRouter requests, so this is the cost-exfiltration ceiling.
# Default: 20 req per 60s.
# THROTTLE_STREAMING_LIMIT=20
# THROTTLE_STREAMING_TTL_MS=60000
