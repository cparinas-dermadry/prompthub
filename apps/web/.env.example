# Next.js Web — Environment Variables
# Copy this file to .env.local and fill in your values. Never commit .env.local.

# ── Clerk ──────────────────────────────────────────────────────────────────────
# From: Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk redirect URLs (these values match the file-system routes in src/app/)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Backend API ───────────────────────────────────────────────────────────────
# Local development: NestJS runs on port 3001
# Production: set to your Railway backend URL e.g. https://api.prompthub.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001
